{
  "manifest_version": 3,
  "name": "MultiSubtitle",
  "version": "0.1.0",
  "description": "Render a selectable second subtitle track on Netflix playback pages, for language learning.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["*://*.netflix.com/*", "*://*.nflxvideo.net/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Subtitle MVP",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["src/subtitle-parser.js", "src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/page-hook.js"],
      "matches": ["*://*.netflix.com/*"]
    }
  ]
}
